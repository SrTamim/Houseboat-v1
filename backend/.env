# ── Core ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000

# ── Database (PostgreSQL 17, local) ───────────────────
DATABASE_URL=postgresql://postgres:admin123@localhost:5432/houseboat?schema=public

# ── Redis (optional in early dev; app boots without it) ─
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=dev-change-me-0e94ad-long-random-string-please
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-change-me-refresh-long-random-string
JWT_REFRESH_EXPIRES_IN=30d
CSRF_SECRET=dev-change-me-csrf-secret-32-bytes-min-ok
COOKIE_SECURE=false

# ── Object storage (S3 / Cloudflare R2) — fill later ──
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=houseboat
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ── Web Push (VAPID) — fill later ─────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ── Payment gateway — fill later ──────────────────────
GATEWAY_BASE_URL=
GATEWAY_API_KEY=
GATEWAY_WEBHOOK_SECRET=
