# ── Core ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# API docs at /api/docs. On by default in dev; set true to expose in prod.
SWAGGER_ENABLED=false
# Public URL of the frontend, for CORS + cookie domain + e-ticket links
WEB_ORIGIN=http://localhost:3000

# ── Database (PostgreSQL / Supabase in prod) ──────────
# Local: your own Postgres. Prod: Supabase — use the connection-pooler URL and
# append ?sslmode=require&pgbouncer=true. Keep a direct (non-pooled) URL for
# `prisma migrate deploy` if using pgbouncer.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/houseboat?schema=public

# ── Redis (cache + rate-limit + hold-sweeper coordination) ─
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=30d
CSRF_SECRET=change-me-32-bytes-min
# App-layer PII encryption (refund bank details). 32+ chars in production.
ENCRYPTION_KEY=change-me-32-bytes-min
# MUST be true in production (cookies only sent over HTTPS). Startup fails otherwise.
COOKIE_SECURE=false

# ── Object storage: Cloudflare R2 (S3-compatible) ─────
# Endpoint: https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=houseboat
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public bucket / CDN base for serving images, e.g. https://media.yourdomain.com
S3_PUBLIC_BASE_URL=

# ── Web Push (VAPID) ──────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ── Public URLs (gateway redirects, IPN, e-ticket links) ──
API_PUBLIC_URL=http://localhost:4000

# ── Payment gateway (SSLCommerz — Bangladesh) ─────────────
GATEWAY_PROVIDER=sslcommerz
# true = SSLCommerz sandbox host + test store. Set false for live.
SSLCZ_SANDBOX=true
SSLCZ_STORE_ID=
SSLCZ_STORE_PASSWORD=

# ── Notifications: SMS (BD) + Email (SMTP) ────────────────
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=
SMTP_URL=
EMAIL_FROM=no-reply@houseboat.local
